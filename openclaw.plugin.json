{
  "id": "tabby-control",
  "name": "TabbyControl",
  "description": "通过 WebSocket 控制 Android 设备。Tabby 下发自然语言任务，手机端自主执行。",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "device_list",
      "device_execute_task",
      "device_execute_task_all",
      "device_execute_batch",
      "device_cancel_task",
      "device_get_status"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "wsPort": {
        "type": "number",
        "description": "WebSocket 服务端口，监听手机连接。",
        "default": 18790
      },
      "rpcPort": {
        "type": "number",
        "default": 18801,
        "description": "HTTP RPC port for controller queries"
      },
      "authTokenLifetime": {
        "type": "number",
        "description": "配对 Token 有效期（秒）。",
        "default": 86400
      },
      "maxDevices": {
        "type": "number",
        "description": "最大同时连接设备数。",
        "default": 10
      }
    }
  }
}
