{
  "name": "@youngclaw/tabby-control",
  "version": "2026.3.2",
  "description": "Remote Android device control plugin for Tabby. Manages WebSocket connections with Tababy Android app and exposes device control as tools.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./protocol": {
      "import": "./dist/protocol.js",
      "types": "./dist/protocol.d.ts"
    },
    "./ws-server": {
      "import": "./dist/ws-server.js",
      "types": "./dist/ws-server.d.ts"
    },
    "./task-coordinator": {
      "import": "./dist/task-coordinator.js",
      "types": "./dist/task-coordinator.d.ts"
    },
    "./bridge": {
      "import": "./dist/bridge.js",
      "types": "./dist/bridge.d.ts"
    },
    "./mqtt-broker": {
      "import": "./dist/mqtt-broker.js",
      "types": "./dist/mqtt-broker.d.ts"
    },
    "./mqtt-phone-proxy": {
      "import": "./dist/mqtt-phone-proxy.js",
      "types": "./dist/mqtt-phone-proxy.d.ts"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "build:watch": "tsc --project tsconfig.build.json --watch",
    "build:nexu": "node scripts/build-nexu.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0"
  },
  "keywords": [
    "tabby",
    "tabby-plugin",
    "android",
    "device-control",
    "websocket"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "aedes": "^1.0.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  }
}
